<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="8dp"
    tools:context=".MainActivity">

    <!-- Top Header and Connection Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Team ЯTR Glider Avionics"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Android Telemetry Dashboard"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:weightSum="3">

        <Button
            android:id="@+id/btnCalibrate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="@color/accent_cyan"
            android:text="CALIB ZERO"
            android:textColor="@color/bg_dark"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingLeft="2dp"
            android:paddingRight="2dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:singleLine="true"
            app:cornerRadius="6dp" />

        <Button
            android:id="@+id/btnStartOTA"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:backgroundTint="@color/accent_red"
            android:text="START OTA"
            android:textColor="@color/text_primary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingLeft="2dp"
            android:paddingRight="2dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:singleLine="true"
            app:cornerRadius="6dp" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="@color/accent_blue"
            android:text="CONNECT"
            android:textColor="@color/text_primary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingLeft="2dp"
            android:paddingRight="2dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:singleLine="true"
            app:cornerRadius="6dp" />
    </LinearLayout>

    <!-- Top Telemetry Status Strip -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="8dp"
        app:cardBackgroundColor="@color/card_dark"
        app:cardElevation="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:weightSum="4">

            <TextView
                android:id="@+id/tvBattery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BAT: 0.00V"
                android:textColor="@color/accent_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvPressure"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BARO: 0.0 hPa"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvAltitude"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LALT: 0.00m"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvGPSSats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="GPS: 0 Sat"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Main flight panel 3x2 Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3.2"
        android:orientation="vertical"
        android:weightSum="2"
        android:layout_marginBottom="8dp">

        <!-- Top Row: ASI, ATT, ALT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="8dp">

            <com.rtr.telemetry.AirspeedIndicatorView
                android:id="@+id/asiView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp" />

            <com.rtr.telemetry.AttitudeIndicatorView
                android:id="@+id/attView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:layout_marginStart="4dp" />

            <com.rtr.telemetry.AltimeterIndicatorView
                android:id="@+id/altView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Bottom Row: Map, HDG, CAN Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Google Map Frame -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardElevation="0dp">
                <com.google.android.gms.maps.MapView
                    android:id="@+id/mapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </androidx.cardview.widget.CardView>

            <com.rtr.telemetry.HeadingIndicatorView
                android:id="@+id/hdgView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:layout_marginStart="4dp" />

            <!-- CAN Monitor 6-system Status Grid -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="8dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CAN NODES"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="6dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:columnCount="2"
                        android:rowCount="4"
                        android:alignmentMode="alignMargins"
                        android:columnOrderPreserved="false">

                        <!-- Main Board -->
                        <TextView
                            android:id="@+id/tvNodeMain"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:layout_margin="3dp"
                            android:background="@android:color/holo_red_dark"
                            android:text="MN"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:padding="4dp" />

                        <!-- Pitot Board -->
                        <TextView
                            android:id="@+id/tvNodePitot"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:layout_margin="3dp"
                            android:background="@android:color/holo_red_dark"
                            android:text="PT"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:padding="4dp" />

                        <!-- Rudder Board -->
                        <TextView
                            android:id="@+id/tvNodeRudder"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:layout_margin="3dp"
                            android:background="@android:color/holo_red_dark"
                            android:text="RD"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:padding="4dp" />

                        <!-- GPS Board -->
                        <TextView
                            android:id="@+id/tvNodeGPS"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:layout_margin="3dp"
                            android:background="@android:color/holo_red_dark"
                            android:text="GP"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:padding="4dp" />

                        <!-- Altimeter Board -->
                        <TextView
                            android:id="@+id/tvNodeAltimeter"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:layout_margin="3dp"
                            android:background="@android:color/holo_red_dark"
                            android:text="AL"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:padding="4dp" />

                        <!-- Sim Bridge -->
                        <TextView
                            android:id="@+id/tvNodeBridge"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:layout_margin="3dp"
                            android:background="@android:color/holo_red_dark"
                            android:text="SP"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:padding="4dp" />

                        <!-- Ladder Board (Hidden) -->
                        <TextView
                            android:id="@+id/tvNodeLadder"
                            android:visibility="gone"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:layout_margin="3dp"
                            android:background="@android:color/holo_red_dark"
                            android:text="LD"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:padding="4dp" />

                        <!-- Elevator Board -->
                        <TextView
                            android:id="@+id/tvNodeElevator"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_rowWeight="1"
                            android:layout_margin="3dp"
                            android:background="@android:color/holo_red_dark"
                            android:text="EV"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:padding="4dp" />

                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Console Logging -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONSOLE LOG"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp"/>
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="8dp"
        app:cardBackgroundColor="@color/card_dark"
        app:cardElevation="0dp">
        <ScrollView
            android:id="@+id/scrollConsole"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:scrollbarThumbVertical="@android:color/transparent">
            <TextView
                android:id="@+id/tvConsole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Disconnected. Click 'CONNECT' to pair."
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </ScrollView>
    </androidx.cardview.widget.CardView>

</LinearLayout>
